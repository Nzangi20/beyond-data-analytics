# Dependencies
node_modules/
server/node_modules/

# Environment configurations
.env
server/.env

# Local SQLite databases and transactional files
server/data/*.db
server/data/*.db-wal
server/data/*.db-shm
server/data/*.db-journal

# Uploads configurations
# Keep materials (since they contain pre-packaged course files) but ignore temporary/dynamic uploads
server/uploads/videos/*
server/uploads/exercises/*
!server/uploads/videos/.gitkeep
!server/uploads/exercises/.gitkeep

# System and IDE files
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
